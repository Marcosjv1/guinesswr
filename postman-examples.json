{
  "postman_examples": {
    "create_record_POST_api_records": {
      "method": "POST",
      "url": "http://localhost:5000/api/records",
      "body": {
        "titulo": "Uñas más largas del mundo",
        "descripcion": "Récord por longitud total de uñas en ambas manos.",
        "poseedor": "Diana Armstrong",
        "anio": 2022,
        "imagenUrl": "https://example.com/images/unas-largas.jpg"
      }
    },
    "get_all_records_GET_api_records": {
      "method": "GET",
      "url": "http://localhost:5000/api/records"
    },
    "get_record_by_id_GET_api_records_id": {
      "method": "GET",
      "url": "http://localhost:5000/api/records/{{recordId}}"
    },
    "update_record_PUT_api_records_id": {
      "method": "PUT",
      "url": "http://localhost:5000/api/records/{{recordId}}",
      "body": {
        "titulo": "Uñas más largas del mundo (Actualizado)",
        "descripcion": "Descripción actualizada del récord.",
        "poseedor": "Diana Armstrong",
        "anio": 2023,
        "imagenUrl": "https://example.com/images/unas-largas-actualizado.jpg"
      }
    },
    "delete_record_DELETE_api_records_id": {
      "method": "DELETE",
      "url": "http://localhost:5000/api/records/{{recordId}}"
    },
    "health_check_GET_api_health": {
      "method": "GET",
      "url": "http://localhost:5000/api/health"
    }
  }
}
